RewriteEngine On
RewriteBase /

# 1. Forzar la eliminación de .php en la URL (Redirección Externa)
# Si alguien entra a dashboard.php, lo manda a /dashboard
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Mapeo Interno
# Si el usuario pide /dashboard, el servidor lee dashboard.php pero no lo muestra
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*?)/?$ $1.php [NC,L]
